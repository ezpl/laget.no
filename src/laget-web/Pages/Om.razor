@page "/om"
@inherits LocalizedComponentBase

<PageTitle>@Lang.T("laget.no — om siden", "laget.no — about")</PageTitle>

<h1 class="page-title"><span class="prompt">&gt;</span>@Lang.T("_om-siden", "_about")</h1>
<p class="page-lead">@Lang.T("Hva dette er.", "What this is.")</p>

<div class="panel manpage">
    <div class="man-h">@Lang.T("NAVN", "NAME")</div>
    <div class="man-body">
        laget<span class="accent">.</span>no
    </div>

    <div class="man-h">@Lang.T("BESKRIVELSE", "DESCRIPTION")</div>
    <div class="man-body">
        @Lang.T("En samling av ting jeg skulle ønske noen hadde forklart meg. Svar på spørsmål stort sett ingen har stilt. Bygget i C#, fordi det virket som en god idé.",
                "A collection of things I wish someone had explained to me. Answers to questions mostly nobody asked. Built in C#, because it seemed like a good idea.")
    </div>

    <div class="man-h">@Lang.T("HISTORIKK", "HISTORY")</div>
    <div class="man-body">
        @Lang.T("Startet med Bantu og kikuyu. Resten er ukjent.",
                "Started with Bantu and Kikuyu. The rest is unknown.")
    </div>

    <div class="man-h">@Lang.T("FEIL", "BUGS")</div>
    <div class="man-body">
        @Lang.T("Garantert. Meld dem på ", "Guaranteed. Report them on ")<a class="inline" href="https://github.com/ezpl/laget.no" target="_blank" rel="noopener">GitHub</a>.
    </div>
</div>
