@implements IDisposable
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject LangService Lang

@if (_open)
{
    <div class="konsoll" @onclick="Close">
        <div class="konsoll__win" @onclick:stopPropagation>
            <div class="konsoll__bar">
                <span class="konsoll__dot"></span>
                <span class="konsoll__title">@Prompt — ~</span>
                <button class="konsoll__x" @onclick="Close" aria-label="@Lang.T("Lukk", "Close")">✕</button>
            </div>

            <div class="konsoll__out" @ref="_outEl">
                @foreach (var line in _lines)
                {
                    <div class="@($"kl {line.Css}")">@((MarkupString)line.Html)</div>
                }
            </div>

            <div class="konsoll__in">
                <span class="konsoll__prompt">@Prompt:~$</span>
                <input @ref="_inputEl" @bind="_input" @bind:event="oninput"
                       @onkeydown="OnKey" class="konsoll__field"
                       autocomplete="off" autocapitalize="off" autocorrect="off"
                       spellcheck="false" aria-label="Terminal" />
            </div>
        </div>
    </div>
}

@code {
    private sealed record Line(string Html, string Css = "");

    private bool _open;
    private string _input = "";
    private readonly List<Line> _lines = new();
    private readonly List<string> _history = new();
    private int _histIndex;
    private ElementReference _inputEl;
    private ElementReference _outEl;
    private bool _focusQueued;

    private string Prompt => Lang.T("gjest@laget.no", "guest@laget.no");

    protected override void OnInitialized()
    {
        KonsollBus.ToggleRequested += Toggle;
        Lang.OnChange += OnLangChanged;
        Print(Lang.T(
            "laget.no terminal — skriv <span class=\"a\">help</span> for kommandoer. Lukk med <span class=\"a\">Esc</span>.",
            "laget.no terminal — type <span class=\"a\">help</span> for commands. Close with <span class=\"a\">Esc</span>."),
            "muted");
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);

    private void Toggle()
    {
        _open = !_open;
        if (_open) _focusQueued = true;
        InvokeAsync(StateHasChanged);
    }

    private void Close()
    {
        _open = false;
        InvokeAsync(StateHasChanged);
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter":
                await Run(_input);
                _input = "";
                break;
            case "Escape":
                Close();
                break;
            case "ArrowUp":
                Recall(-1);
                break;
            case "ArrowDown":
                Recall(1);
                break;
        }
    }

    private void Recall(int delta)
    {
        if (_history.Count == 0) return;
        _histIndex = Math.Clamp(_histIndex + delta, 0, _history.Count);
        _input = _histIndex < _history.Count ? _history[_histIndex] : "";
    }

    private async Task Run(string raw)
    {
        var cmd = raw.Trim();
        Print($"<span class=\"p\">{Prompt}:~$</span> {Escape(cmd)}");
        if (cmd.Length == 0) return;

        _history.Add(cmd);
        _histIndex = _history.Count;

        var parts = cmd.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
        var name = parts[0].ToLowerInvariant();
        var arg = parts.Length > 1 ? parts[1].Trim() : "";

        switch (name)
        {
            case "help":
            case "hjelp":
                Print(Lang.T("tilgjengelige kommandoer:", "available commands:"), "muted");
                Print("  <span class=\"a\">help</span>       " + Lang.T("denne lista", "this list"));
                Print("  <span class=\"a\">ls</span>         " + Lang.T("list temaene", "list the topics"));
                Print("  <span class=\"a\">apper</span>      " + Lang.T("nyttige applikasjoner", "useful applications"));
                Print("  <span class=\"a\">open</span> &lt;navn&gt; " + Lang.T("åpne et tema", "open a topic")
                    + " (<span class=\"a\">open bantu-kikuyu</span>)");
                Print("  <span class=\"a\">whoami</span>     " + Lang.T("hvem er du", "who you are"));
                Print("  <span class=\"a\">uname</span>      " + Lang.T("hva siden kjører på", "what the site runs on"));
                Print("  <span class=\"a\">date</span>       " + Lang.T("klokka nå", "the time now"));
                Print("  <span class=\"a\">echo</span> &lt;tekst&gt; " + Lang.T("skriv tilbake", "echo back"));
                Print("  <span class=\"a\">snake</span>      🐍");
                Print("  <span class=\"a\">matrix</span>     " + Lang.T("følg den hvite kaninen", "follow the white rabbit"));
                Print("  <span class=\"a\">github</span> · <span class=\"a\">discord</span>   " + Lang.T("finn meg", "find me"));
                Print("  <span class=\"a\">clear</span>      " + Lang.T("tøm skjermen", "clear the screen"));
                Print("  <span class=\"a\">exit</span>       " + Lang.T("lukk terminalen", "close the terminal"));
                break;

            case "ls":
            case "tema":
            case "topics":
                foreach (var t in Temaer.Alle)
                {
                    var status = t.Publisert ? "" : "  <span class=\"muted\">(" + Lang.T("kommer", "coming") + ")</span>";
                    Print($"  <span class=\"g\">{Escape(t.Slug)}</span>  <span class=\"muted\">{Escape(Lang.L(t.Tag))}</span>{status}");
                }
                break;

            case "apper":
            case "apps":
                foreach (var a in Apper.Alle)
                {
                    Print($"  <a class=\"a\" href=\"{a.Href}\" target=\"_blank\" rel=\"noopener\">{Escape(a.Navn)}</a>  <span class=\"muted\">{Escape(Lang.L(a.Om))}</span>");
                }
                break;

            case "open":
            case "cd":
                var match = Temaer.Alle.FirstOrDefault(t =>
                    t.Publisert && string.Equals(t.Slug, arg, StringComparison.OrdinalIgnoreCase));
                if (match is null)
                {
                    Print(Lang.T($"fant ikke tema: <span class=\"a\">{Escape(arg)}</span>. prøv <span class=\"a\">ls</span>.",
                                 $"no such topic: <span class=\"a\">{Escape(arg)}</span>. try <span class=\"a\">ls</span>."), "err");
                }
                else
                {
                    Print(Lang.T($"åpner <span class=\"g\">{Escape(match.Slug)}</span> …",
                                 $"opening <span class=\"g\">{Escape(match.Slug)}</span> …"));
                    Close();
                    Nav.NavigateTo(match.Href, forceLoad: match.Ekstern);
                }
                break;

            case "whoami":
                Print(Lang.T("gjest — velkommen innom 👋", "guest — glad you stopped by 👋"));
                break;

            case "uname":
                Print("laget.no · Blazor WebAssembly · .NET 10 · C# · GitHub Pages");
                break;

            case "date":
            case "klokke":
                Print(DateStr(DateTime.Now));
                break;

            case "echo":
                Print(Escape(arg));
                break;

            case "snake":
                Print(Lang.T("🐍 slangen bor på forsiden — piltaster styrer. Lykke til!",
                             "🐍 the snake lives on the home page — arrow keys steer. Good luck!"));
                break;

            case "matrix":
                Print("wake up, Neo …", "g");
                await JS.InvokeVoidAsync("lagetMatrix", 6);
                break;

            case "github":
                Print("→ <a class=\"a\" href=\"https://github.com/ezpl\" target=\"_blank\" rel=\"noopener\">github.com/ezpl</a>");
                break;

            case "discord":
                Print("→ <a class=\"a\" href=\"https://discord.com/users/705758226058313730\" target=\"_blank\" rel=\"noopener\">.ezpl</a>");
                break;

            case "sudo":
                Print(Lang.T("gjest er ikke i sudoers-fila. Hendelsen er rapportert.",
                             "guest is not in the sudoers file. This incident will be reported."), "err");
                break;

            case "clear":
            case "cls":
                _lines.Clear();
                break;

            case "exit":
            case "quit":
                Close();
                break;

            default:
                Print(Lang.T($"kommando ikke funnet: <span class=\"a\">{Escape(name)}</span>. prøv <span class=\"a\">help</span>.",
                             $"command not found: <span class=\"a\">{Escape(name)}</span>. try <span class=\"a\">help</span>."), "err");
                break;
        }
    }

    private void Print(string html, string css = "") => _lines.Add(new Line(html, css));

    // Dato uten ICU (appen kjører med InvariantGlobalization).
    private string DateStr(DateTime d)
    {
        string[] dagerNb = { "søndag", "mandag", "tirsdag", "onsdag", "torsdag", "fredag", "lørdag" };
        string[] mndNb = { "januar", "februar", "mars", "april", "mai", "juni",
                           "juli", "august", "september", "oktober", "november", "desember" };
        string[] daysEn = { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
        string[] monthsEn = { "January", "February", "March", "April", "May", "June",
                              "July", "August", "September", "October", "November", "December" };
        return Lang.IsEn
            ? $"{daysEn[(int)d.DayOfWeek]} {d.Day} {monthsEn[d.Month - 1]} {d.Year}, {d:HH:mm:ss}"
            : $"{dagerNb[(int)d.DayOfWeek]} {d.Day}. {mndNb[d.Month - 1]} {d.Year}, {d:HH:mm:ss}";
    }

    private static string Escape(string s) => s
        .Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusQueued)
        {
            _focusQueued = false;
            try { await _inputEl.FocusAsync(); } catch { /* elementet kan være borte */ }
        }
        if (_open)
        {
            await JS.InvokeVoidAsync("lagetScrollBottom", _outEl);
        }
    }

    public void Dispose()
    {
        KonsollBus.ToggleRequested -= Toggle;
        Lang.OnChange -= OnLangChanged;
    }
}
