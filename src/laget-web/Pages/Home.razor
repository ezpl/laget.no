@page "/"
@inherits LocalizedComponentBase
@inject NavigationManager Nav

<PageTitle>@Lang.T("laget.no — informasjon & nyttige ting", "laget.no — information & useful things")</PageTitle>

<div class="hei">

    <section>
        <p class="eyebrow">@Lang.T("// svar på spørsmål stort sett ingen har stilt", "// answers to questions mostly nobody asked")</p>
        <h1 class="hero">laget<span class="dot">.</span>no</h1>
        <p class="hero-sub"><span class="prompt">&gt;</span> @Lang.T("informasjon & nyttige ting", "information & useful things")</p>

        <div class="codeblock">
            <span class="ln comment">@Lang.T("// temaene på siden — åpne et under _tema", "// topics on the site — open one under _topics")</span>
            <span class="ln"><span class="prompt">const</span> <span class="green">tema</span> = [</span>
            @foreach (var t in Temaer.Alle.Where(t => t.Publisert))
            {
                <span class="ln ln--indent">{ navn: <a class="accent tema-link" href="@t.Href" @onclick="() => Aapne(t)" @onclick:preventDefault>'@t.Slug'</a>, tag: <span class="accent">'@Lang.L(t.Tag)'</span> },</span>
            }
            <span class="ln ln--indent coming">@Lang.T("// flere kommer …", "// more coming …")</span>
            <span class="ln">];</span>
        </div>

        <div class="codeblock">
            <span class="ln comment">@Lang.T("// nyttige apper — detaljer under _tema", "// useful apps — details under _topics")</span>
            <span class="ln"><span class="prompt">const</span> <span class="green">apper</span> = [</span>
            @foreach (var a in Apper.Alle)
            {
                <span class="ln ln--indent"><a class="accent tema-link" href="@a.Href" target="_blank" rel="noopener">'@a.Navn'</a>,</span>
            }
            <span class="ln">];</span>
        </div>

        <p class="hint">
            @Lang.T("Tips: mens du er her — ", "Tip: while you're here — ")<kbd>↑</kbd> <kbd>←</kbd> <kbd>↓</kbd> <kbd>→</kbd> @Lang.T("styrer slangen.", "steer the snake.")
        </p>
    </section>

    <Snake />

</div>

@code {
    private void Aapne(Models.Tema t) => Nav.NavigateTo(t.Href, forceLoad: t.Ekstern);
}
